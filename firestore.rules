rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isTreeOwner(uid) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(uid)/members-access/$(request.auth.uid)).data.role == 'owner';
    }

    function isBranchEditor(uid) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(uid)/members-access/$(request.auth.uid)).data.role == 'branch_editor';
    }

    function isTreeMember(uid) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(uid)/members-access/$(request.auth.uid));
    }

    // ─── Users ───
    match /users/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow create: if isUser(uid);
      allow update: if isUser(uid) || isAdmin();
      allow delete: if false;
    }

    // ─── Members ───
    match /users/{uid}/members/{memberId} {
      allow read: if isTreeMember(uid);
      allow create: if isTreeOwner(uid) || isBranchEditor(uid);
      allow update: if isTreeOwner(uid) ||
        (isBranchEditor(uid) && resource.data.addedBy == request.auth.uid);
      allow delete: if false; // Soft delete only
    }

    // ─── Marriages ───
    match /users/{uid}/members/{memberId}/marriages/{marriageId} {
      allow read: if isTreeMember(uid);
      allow create: if isTreeOwner(uid) || isBranchEditor(uid);
      allow update: if isTreeOwner(uid) ||
        (isBranchEditor(uid) && resource.data.addedBy == request.auth.uid);
      allow delete: if false;
    }

    // ─── Members Access ───
    match /users/{uid}/members-access/{memberUid} {
      allow read: if isUser(uid) || isUser(memberUid) || isAdmin();
      allow write: if isTreeOwner(uid) || isAdmin();
    }

    // ─── Households ───
    match /users/{uid}/households/{householdId} {
      allow read: if isTreeMember(uid);
      allow write: if isTreeOwner(uid) || isBranchEditor(uid);
    }

    // ─── Tree Metadata (public read for WhatsApp links) ───
    match /tree-metadata/{treeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // ─── Gotra Index (same gotra only) ───
    match /gotra-index/{gotra}/{treeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Join Requests ───
    match /join-requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ─── Connections ───
    match /connections/{connectionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ─── Duplicate Alerts ───
    match /duplicate-alerts/{alertId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Admin ───
    match /admins/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow write: if false;
    }

    match /admin-actions/{actionId} {
      allow read, write: if isAdmin();
    }
  }
}
